{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "install": {
          "cmds": ["cd mcp-server && npm install"]
        },
        "build": {
          "cmds": ["cd mcp-server && npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd mcp-server && node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
